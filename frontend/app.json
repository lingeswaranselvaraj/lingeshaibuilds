{
  "expo": {
    "name": "LoHaa - Learn Cantonese",
    "slug": "lohaa",
    "version": "1.0.0",
    "scheme": "lohaa",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#1a0a2e"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.lohaa.app"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#1a0a2e"
      },
      "edgeToEdgeEnabled": true,
      "package": "com.lohaa.app"
    },
    "web": {
      "bundler": "metro",
      "favicon": "./assets/favicon.png",
      "output": "static"
    },
    "plugins": ["expo-router", "expo-av"],
    "experiments": {
      "typedRoutes": true
    }
  }
}
